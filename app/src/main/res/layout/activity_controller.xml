<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000"
    android:screenOrientation="landscape"> <View
        android:id="@+id/joystick_base"
        android:layout_width="150dp"
        android:layout_height="150dp"
        android:layout_alignParentStart="true"
        android:layout_centerVertical="true"
        android:layout_marginStart="50dp"
        android:background="@drawable/btn_controller"
        android:alpha="0.5" />

    <GridLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_alignParentEnd="true"
        android:layout_centerVertical="true"
        android:layout_marginEnd="50dp"
        android:columnCount="2">

        <Button android:id="@+id/btn_y" android:layout_margin="10dp" android:text="Y" 
            android:background="@drawable/btn_controller" android:textColor="#FFD600" />
        <Button android:id="@+id/btn_x" android:layout_margin="10dp" android:text="X" 
            android:background="@drawable/btn_controller" android:textColor="#00E5FF" />
        <Button android:id="@+id/btn_a" android:layout_margin="10dp" android:text="A" 
            android:background="@drawable/btn_controller" android:textColor="#00FF00" />
        <Button android:id="@+id/btn_b" android:layout_margin="10dp" android:text="B" 
            android:background="@drawable/btn_controller" android:textColor="#FF1744" />
    </GridLayout>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_centerInParent="true"
        android:text="ZENITH CONTROLLER: CONNECTED TO XIAOMI TV"
        android:textColor="#00E5FF"
        android:textSize="10sp"
        android:alpha="0.3"/>

</RelativeLayout>
