<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/rootLayout"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/premium_floating_bg"
    android:padding="2dp">

    <LinearLayout
        android:id="@+id/dragHandle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:background="#22FFFFFF"
        android:padding="4dp">

        <ImageView android:id="@+id/btnHide" android:layout_width="40dp" android:layout_height="40dp"
            android:padding="8dp" android:src="@android:drawable/ic_menu_sort_by_size" android:tint="#FF1744" />

        <ImageView android:id="@+id/btnRunBgmi" android:layout_width="40dp" android:layout_height="40dp"
            android:padding="8dp" android:src="@android:drawable/ic_media_play" android:tint="#00E5FF" />

        <ImageView android:id="@+id/btnSmartRun" android:layout_width="40dp" android:layout_height="40dp"
            android:padding="8dp" android:src="@android:drawable/ic_dialog_dialer" android:tint="#FFD600" />

        <ImageView android:id="@+id/btnClose" android:layout_width="40dp" android:layout_height="40dp"
            android:padding="8dp" android:src="@android:drawable/ic_menu_close_clear_cancel" android:tint="#B0BEC5" />
    </LinearLayout>

    <ScrollView
        android:id="@+id/featureContainer"
        android:layout_width="220dp"
        android:layout_height="250dp"
        android:visibility="gone">

        <LinearLayout
            android:id="@+id/modListLayout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="8dp">
            
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="ENGINE ACTIVE"
                android:textColor="#FF1744"
                android:textSize="10sp"
                android:textStyle="bold"
                android:gravity="center"
                android:layout_marginBottom="8dp"/>
        </LinearLayout>
    </ScrollView>
</LinearLayout>
