<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content">

    <ImageView
        android:id="@+id/collapsedIcon"
        android:layout_width="52dp"
        android:layout_height="52dp"
        android:src="@drawable/ic_launcher"
        android:background="@drawable/premium_floating_bg"
        android:padding="10dp"
        android:visibility="gone" />

    <LinearLayout
        android:id="@+id/expandedMenu"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@drawable/premium_floating_bg"
        android:padding="4dp">

        <LinearLayout
            android:id="@+id/controlBar"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:background="#1AFFFFFF"
            android:padding="6dp">

            <ImageView android:id="@+id/btnHide" android:layout_width="38dp" android:layout_height="38dp"
                android:padding="8dp" android:src="@android:drawable/ic_menu_sort_by_size" android:tint="#FF1744" />

            <ImageView android:id="@+id/btnRunBgmi" android:layout_width="38dp" android:layout_height="38dp"
                android:padding="8dp" android:src="@android:drawable/ic_media_play" android:tint="#00E5FF" />

            <ImageView android:id="@+id/btnSmartRun" android:layout_width="38dp" android:layout_height="38dp"
                android:padding="8dp" android:src="@android:drawable/ic_dialog_dialer" android:tint="#FFD600" />

            <ImageView android:id="@+id/btnClose" android:layout_width="38dp" android:layout_height="38dp"
                android:padding="8dp" android:src="@android:drawable/ic_menu_close_clear_cancel" android:tint="#FFFFFF" />
        </LinearLayout>

        <ScrollView
            android:id="@+id/contentScroll"
            android:layout_width="220dp"
            android:layout_height="260dp"
            android:layout_marginTop="5dp">

            <LinearLayout
                android:id="@+id/dynamicContentLayout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="10dp">
                </LinearLayout>
        </ScrollView>
    </LinearLayout>
</FrameLayout>
