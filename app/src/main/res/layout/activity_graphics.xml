<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/colorBackground">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🎨 Graphics Optimization"
            android:textColor="@color/white"
            android:textSize="22sp"
            android:textStyle="bold"
            android:layout_marginBottom="20dp"/>

        <RadioGroup
            android:id="@+id/rgGraphics"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="@color/colorCardBackground"
                app:cardCornerRadius="12dp"
                android:layout_marginBottom="12dp">
                <RadioButton
                    android:id="@+id/rbUltraExtreme"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="16dp"
                    android:text="🚀 Ultra Extreme (144 FPS Unlock)"
                    android:textColor="@color/colorSuccess"
                    android:buttonTint="@color/colorSuccess" />
            </androidx.cardview.widget.CardView>

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="@color/colorCardBackground"
                app:cardCornerRadius="12dp"
                android:layout_marginBottom="12dp">
                <RadioButton
                    android:id="@+id/rbSmooth"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="16dp"
                    android:text="Smooth Performance (Stable)"
                    android:textColor="@color/white"
                    android:buttonTint="@color/colorPrimary" />
            </androidx.cardview.widget.CardView>

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="@color/colorCardBackground"
                app:cardCornerRadius="12dp"
                android:layout_marginBottom="12dp">
                <RadioButton
                    android:id="@+id/rbUltraHdr"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="16dp"
                    android:text="Ultra HDR + Cinema Mode"
                    android:textColor="@color/white"
                    android:buttonTint="@color/colorPrimary" />
            </androidx.cardview.widget.CardView>
        </RadioGroup>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Extra Optimizations"
            android:textColor="@color/colorTextSecondary"
            android:layout_marginTop="20dp"
            android:layout_marginBottom="10dp"/>

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardBackgroundColor="@color/colorCardBackground"
            app:cardCornerRadius="12dp">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="8dp">
                
                <com.google.android.material.switchmaterial.SwitchMaterial
                    android:id="@+id/switchAntiLag"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Anti-Lag Engine"
                    android:textColor="@color/white"
                    android:padding="12dp" />

                <com.google.android.material.switchmaterial.SwitchMaterial
                    android:id="@+id/switchUnlock144"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Force 144Hz Refresh Rate"
                    android:textColor="@color/white"
                    android:padding="12dp" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btnApplyGraphics"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:layout_marginTop="30dp"
            android:text="⚡ APPLY BEST GRAPHICS"
            android:textColor="@color/white"
            android:textStyle="bold"
            android:background="@drawable/premium_primary_bg" />

    </LinearLayout>
</ScrollView>
