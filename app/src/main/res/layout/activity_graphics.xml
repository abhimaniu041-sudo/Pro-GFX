<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/colorBackground">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🎨 Graphics Optimization"
            android:textColor="@color/white"
            android:textSize="22sp"
            android:textStyle="bold"
            android:layout_marginBottom="20dp"/>

        <RadioGroup
            android:id="@+id/rgGraphics"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <RadioButton
                android:id="@+id/rbUltraExtreme"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="🚀 Ultra Extreme (144 FPS Unlock)"
                android:textColor="@color/white"
                android:padding="12dp"
                android:layout_marginBottom="8dp"/>

            <RadioButton
                android:id="@+id/rbSmooth"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Smooth Performance (Stable)"
                android:textColor="@color/white"
                android:padding="12dp"
                android:layout_marginBottom="8dp"/>

            <RadioButton
                android:id="@+id/rbRestore"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="🔄 Restore Original Graphics"
                android:textColor="@color/white"
                android:padding="12dp"
                android:layout_marginBottom="8dp"/>
        </RadioGroup>

        <Switch
            android:id="@+id/switchAntiLag"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Anti-Lag Engine"
            android:textColor="@color/white"
            android:padding="12dp"
            android:layout_marginTop="20dp"/>

        <Switch
            android:id="@+id/switchUnlock144"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Force 144Hz Refresh Rate"
            android:textColor="@color/white"
            android:padding="12dp"/>

        <Button
            android:id="@+id/btnApplySettings"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:layout_marginTop="30dp"
            android:text="⚡ APPLY SETTINGS"
            android:backgroundTint="@color/colorPrimary"
            android:textColor="@color/white" />

    </LinearLayout>
</ScrollView>
